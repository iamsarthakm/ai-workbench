# App
ENVIRONMENT=local
LOG_LEVEL=INFO
UVICORN_WORKERS=1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/__DB_NAME__

# Security
SECRET_KEY=
JWT_EXPIRE_MINUTES=1440  # access token lifetime (minutes); 1440 = 1 day

# Observability
SENTRY_DSN=

# CORS — comma-separated origins, e.g. https://app.example.com,https://admin.example.com
# "*" (default) disables credentialed CORS; see app/core/config.py.
CORS_ORIGINS=*
